# --- LLM Configuration ---
# Choose your provider: 'openai', 'anthropic', 'github', or 'ollama'
LLM_PROVIDER=openai

# Optional: Override the default model for your provider (e.g., gpt-4o, claude-3-5-sonnet-20240620, llama3)
# LLM_MODEL=gpt-4o

# Optional: Override the default temperature (default: 0)
# LLM_TEMPERATURE=0

# Provide the API key for your chosen provider (not needed for ollama)
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GITHUB_TOKEN=your_github_personal_access_token_here

# Optional: If using Ollama, override the default base URL if your server is hosted remotely
# OLLAMA_BASE_URL=http://localhost:11434

# --- Version Control Integration (Optional) ---
# If you set GITHUB_TOKEN for the LLM, you can also set GITHUB_REPO to enable real GitHub branch and PR creation!
# GITHUB_REPO=owner/repo_name

# --- Linear Integration (Optional) ---
# Provide both to enable real Linear ticket creation instead of mocks.
LINEAR_API_KEY=your_linear_api_key_here
LINEAR_TEAM_ID=your_linear_team_id_here
