# --- LLM Configuration ---
# Choose your provider: 'openai', 'anthropic', or 'github'
LLM_PROVIDER=openai

# Optional: Override the default model for your provider (e.g., gpt-4o, claude-3-5-sonnet-20240620)
# LLM_MODEL=gpt-4o

# Optional: Override the default temperature (default: 0)
# LLM_TEMPERATURE=0

# Provide the API key for your chosen provider
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GITHUB_TOKEN=your_github_personal_access_token_here

# --- Linear Integration (Optional) ---
# Provide both to enable real Linear ticket creation instead of mocks.
LINEAR_API_KEY=your_linear_api_key_here
LINEAR_TEAM_ID=your_linear_team_id_here
